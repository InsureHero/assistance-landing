# =============================================================================
# Landing – variables de entorno para consumo del API Shield
# Copia este archivo a .env.local y rellena los valores.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Backend Shield (obligatorio)
# -----------------------------------------------------------------------------
# URL base del API Shield. El proxy reenvía /api/shield/* a esta URL.
# Ejemplo: http://localhost:3000 (si el API corre en el mismo equipo).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 2) Autenticación (obligatorio)
# -----------------------------------------------------------------------------
# API key del channel. Se usa en /api/shield/v1/auth/authorize para obtener
# el Bearer token. Puede ser la misma que usa el dashboard del channel.
# En el cliente solo está disponible NEXT_PUBLIC_* (authorize, OTP desde el proxy).
NEXT_PUBLIC_USD_API_KEY=
USD_API_KEY=

# -----------------------------------------------------------------------------
# 3) Channel ID – header x-channel-id (obligatorio con login OTP)
# -----------------------------------------------------------------------------
# UUID del channel (tabla channels.id en el API). No usar api_key.
# Con login OTP el token tiene sub=email, por eso risk-items necesita este valor.
# Ejemplo: fc94d4a1-f834-481d-a6b2-138b823389c8 (consulta channels.id en la base del API).
X_CHANNEL_ID=
# Opcional: si necesitas x-channel-id en el cliente (p. ej. llamadas directas
# al proxy desde el navegador), define también:
# NEXT_PUBLIC_X_CHANNEL_ID=

# -----------------------------------------------------------------------------
# 4) Opcional – segundo channel (p. ej. MXN)
# -----------------------------------------------------------------------------
# MXN_API_KEY=
# NEXT_PUBLIC_MXN_API_KEY=
