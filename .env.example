# =============================================================================
# Landing Vidanta – variables de entorno (API Postventa)
# Copia este archivo a .env.local y rellena los valores.
# El landing usa OTP y token Bearer; no requiere API key ni channel id.
# =============================================================================

# -----------------------------------------------------------------------------
# API Postventa (obligatorio)
# -----------------------------------------------------------------------------
# URL base del backend InsureHero (API postventa: OTP, risk-items, beneficiarios).
# Entorno develop: https://develop.insurehero.io
# Local: http://localhost:3000
NEXT_PUBLIC_POSTVENTA_API_URL=https://develop.insurehero.io

# Opcional: misma URL como fallback (getBaseUrl usa POSTVENTA primero).
# NEXT_PUBLIC_API_BASE_URL=https://develop.insurehero.io

# -----------------------------------------------------------------------------
# Post-sales integrations (opcional)
# -----------------------------------------------------------------------------
# URL base para consumir el API de post-sales (POST /api/integrations/post-sales).
# Sin esta variable el landing no enviará la sincronización de beneficiarios a post-sales.
# Mismo entorno develop: https://develop.insurehero.io
NEXT_PUBLIC_POST_SALES_API_URL=

# UUID del channel para el body de POST /api/integrations/post-sales (mapear por rama/entorno).
NEXT_PUBLIC_POST_SALES_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Opcional
# -----------------------------------------------------------------------------
# URL de la página de política de privacidad (enlace en el paso de viajeros).
# NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy-policy

